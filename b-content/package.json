{
    "name": "b-content",
    "version": "1.0.0-beta.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "test": "npx playwright test",
        "test:smoke": "npx playwright test tests/smoke.spec.ts",
        "db:migrate": "wrangler d1 execute b-content-db --local --file=db/schema.sql",
        "typecheck": "tsc --noEmit",
        "release": "commit-and-tag-version",
        "release:beta": "commit-and-tag-version --prerelease beta",
        "release:first": "commit-and-tag-version --first-release"
    },
    "dependencies": {
        "hono": "^4.12.7",
        "lucide-react": "^0.577.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.0.0",
        "@cloudflare/workers-types": "^4.20260301.0",
        "@playwright/test": "^1.50.0",
        "@tailwindcss/vite": "^4.1.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "@vitejs/plugin-react": "^4.4.0",
        "commit-and-tag-version": "^12.6.1",
        "tailwindcss": "^4.1.0",
        "typescript": "^5.8.0",
        "vite": "^6.3.0",
        "wrangler": "^4.0.0"
    }
}
